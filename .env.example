# Spatial Standards — sample environment file.
#
# Copy to .env, fill in, and load it before running, e.g.:
#   set -a; . ./.env; set +a
# (.env is gitignored; this .env.example is the committed template.)
# Note: these are read from the process environment — the app does not parse
# .env itself, so source it as above (or export the vars another way).

# Natural Perspective — your Anthropic API key (bring-your-own-key).
# Leave blank to fall back to the default config (works fully offline).
ANTHROPIC_API_KEY=

# Optional — override external tool locations (otherwise found on PATH).
# The GUI reads these; the CLI also accepts --ffmpeg-bin / --demucs-bin / etc.
#SPATIAL_STANDARDS_FFMPEG=ffmpeg
#SPATIAL_STANDARDS_DEMUCS=demucs
#SPATIAL_STANDARDS_SEPARATOR=audio-separator
#SPATIAL_STANDARDS_YTDLP=yt-dlp

# Optional — disable the separation/download cache.
#SPATIAL_STANDARDS_NO_CACHE=1

# Optional — cache location (defaults to ~/.cache/spatial-standards).
#XDG_CACHE_HOME=

# Optional — force the GUI HiDPI scale factor (1.0–4.0).
#SPATIAL_STANDARDS_UI_SCALE=
